# TEMPORARY: Prevent ALL caching for HTML to fix stale content issues
/*.html
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

/
  Cache-Control: no-cache, no-store, must-revalidate
  Pragma: no-cache
  Expires: 0

# Cache static assets for 1 year (immutable since filenames contain hashes)
/assets/*
  Cache-Control: public, max-age=31536000, immutable

# Cache JavaScript files for 1 year
/assets/*.js
  Cache-Control: public, max-age=31536000, immutable

# Cache CSS files for 1 year
/assets/*.css
  Cache-Control: public, max-age=31536000, immutable

# Cache images for 1 year
