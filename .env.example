# ── Supabase ──────────────────────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Stripe (client-side) ──────────────────────────────────────────────────────
# Found in: Stripe Dashboard → Developers → API Keys → Publishable key
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# ── Supabase Edge Function secrets (set via Supabase Dashboard or CLI) ────────
# supabase secrets set KEY=value

# Resend API key — https://resend.com/api-keys
RESEND_API_KEY=re_...

# Verified "from" address on your Resend domain (e.g. hello@corineruben.com)
SENDER_EMAIL=hello@corineruben.com

# Your personal email address to receive contact form & admin notifications
ADMIN_EMAIL=your@email.com

# Stripe secret key (used in create-gift-intent edge function)
# Found in: Stripe Dashboard → Developers → API Keys → Secret key
STRIPE_SECRET_KEY=sk_live_...
